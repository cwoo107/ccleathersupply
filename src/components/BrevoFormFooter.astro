<!-- Brevo stylesheet — only load once per page; if BrevoForm.astro is also present, remove this line -->
<link rel="stylesheet" href="https://sibforms.com/forms/end-form/build/sib-styles.css">

<style>
  #footer-sib-container * { box-sizing: border-box; }
  #footer-sib-container .sib-form,
  #footer-sib-container .sib-form-container { background: none !important; padding: 0 !important; }
  #footer-sib-container #sib-form-container { background: none !important; }
#footer-sib-container #sib-container {
  background: none !important;
  padding: 0 !important;
  margin: 0 !important;
  display: block !important;
}  /* Messages */
  #error-message,
  #success-message {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 0.8rem;
    padding: 0.6rem 0.875rem;
    margin-bottom: 0.75rem;
    border-left: 2px solid;
  }
  #error-message   { color: #ffb3b3; background: rgba(255,73,73,0.15); border-color: #ff4949; }
  #success-message { color: #a3d9b5; background: rgba(19,206,102,0.1); border-color: #13ce66; }
  .footer-sib-message-text { display: flex; align-items: center; gap: 0.5rem; }
  .footer-sib-icon { width: 0.875rem; height: 0.875rem; flex-shrink: 0; fill: currentColor; }

  /* Hide Brevo's default labels */
  #footer-sib-container .entry__label,
  #footer-sib-container .entry__specification { display: none !important; }

  /* Input */
  #footer-sib-container #sib-form .input {
    all: unset;
    box-sizing: border-box;
    display: block;
    width: 100%;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(242,232,208,0.1);
    color: #6b1e1e;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 0.875rem;
    padding: 0.65rem 1rem;
    transition: border-color 0.2s;
  }
  #footer-sib-container #sib-form .input:focus {
    outline: none;
    border-color: rgba(201,168,76,0.5);
  }
  #footer-sib-container #sib-form .input::placeholder {
    color: rgba(242,232,208,0.25);
  }

  /* Button */
  #footer-sib-container .footer-submit-btn {
    all: unset;
    box-sizing: border-box;
    display: block;
    width: 100%;
    cursor: pointer;
    background: #6b1e1e;
    color: #f2e8d0;
    font-family: 'Jost', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-align: center;
    padding: 0.75rem 1rem;
    border: 1px solid #6b1e1e;
    transition: background 0.2s, border-color 0.2s;
  }
  #footer-sib-container .footer-submit-btn:hover {
    background: #4a1515;
    border-color: #4a1515;
  }

  #footer-sib-container .entry__error {
    display: block;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 0.7rem;
    color: #ffb3b3;
    margin-top: 0.25rem;
  }
  #footer-sib-container .entry__error:empty { display: none; }
  .sib-hide-loader-icon { display: none; }

  #footer-sib-container .sib-form-block,
  #footer-sib-container .sib-input,
  #footer-sib-container .form__entry,
  #footer-sib-container .entry__field {
    padding: 0 !important;
    margin: 0 !important;
  }
</style>

<div id="footer-sib-container">
  <div class="sib-form">
    <div id="sib-form-container" class="sib-form-container">

      <!-- Error -->
      <div id="error-message" class="sib-form-message-panel" style="display:none;">
        <div class="footer-sib-message-text">
          <svg viewBox="0 0 512 512" class="footer-sib-icon"><path d="M256 40c118.621 0 216 96.075 216 216 0 119.291-96.61 216-216 216-119.244 0-216-96.562-216-216 0-119.203 96.602-216 216-216m0-32C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm-11.49 120h22.979c6.823 0 12.274 5.682 11.99 12.5l-7 168c-.268 6.428-5.556 11.5-11.99 11.5h-8.979c-6.433 0-11.722-5.073-11.99-11.5l-7-168c-.283-6.818 5.167-12.5 11.99-12.5zM256 340c-15.464 0-28 12.536-28 28s12.536 28 28 28 28-12.536 28-28-12.536-28-28-28z"/></svg>
          <span>Subscription failed. Please try again.</span>
        </div>
      </div>

      <!-- Success -->
      <div id="success-message" class="sib-form-message-panel" style="display:none;">
        <div class="footer-sib-message-text">
          <svg viewBox="0 0 512 512" class="footer-sib-icon"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 464c-118.664 0-216-96.055-216-216 0-118.663 96.055-216 216-216 118.664 0 216 96.055 216 216 0 118.663-96.055 216-216 216zm141.63-274.961L217.15 376.071c-4.705 4.667-12.303 4.637-16.97-.068l-85.878-86.572c-4.667-4.705-4.637-12.303.068-16.97l8.52-8.451c4.705-4.667 12.303-4.637 16.97.068l68.976 69.533 163.441-162.13c4.705-4.667 12.303-4.637 16.97.068l8.451 8.52c4.668 4.705 4.637 12.303-.068 16.97z"/></svg>
          <span>You're subscribed. Welcome to the Covenant Letter.</span>
        </div>
      </div>

      <div id="sib-container">
        <form
          id="sib-form"
          method="POST"
          action="https://0703219b.sibforms.com/serve/MUIFAMyQJC1n8hLEsdUNylXqHtWLj6SPyrMCyos8w93wRhflHVKj3_QQtpFEaV44O0gNbQudqgyx-owK5JPIujnFcvxBWnGn6iN5FVR6ksx-5PokVE2AXEZ-74PiXpn_rRTpOxNtdvZx0wTJ1O3U_2hCkGADpnF7Z7KHFQiPlsYnyzmI8BK4kcYxJ7DHTILe_vHvQg_5udRPLjjQiQ=="
          data-type="subscription"
        >
          <div class="sib-input sib-form-block mb-2">
            <div class="form__entry entry_block">
              <div class="form__label-row mb-2">
                <label class="entry__label" for="FOOTER-EMAIL">Email</label>
                <div class="entry__field ">
                  <input
                    class="input"
                    type="text"
                    id="FOOTER-EMAIL"
                    name="EMAIL"
                    autocomplete="email"
                    placeholder="your@email.com"
                    data-required="true"
                    required
                  />
                </div>
              </div>
              <label class="entry__error entry__error--primary"></label>
            </div>
          </div>

          <div class="sib-form-block">
            <button
              class="sib-form-block__button sib-form-block__button-with-loader footer-submit-btn"
              form="sib-form"
              type="submit"
            >
              <svg class="icon clickable__icon progress-indicator__icon sib-hide-loader-icon" viewBox="0 0 512 512">
                <path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z"/>
              </svg>
              Subscribe
            </button>
          </div>

          <input type="text" name="email_address_check" value="" style="display:none;">
          <input type="hidden" name="locale" value="en">
        </form>
      </div>

    </div>
  </div>
</div>

<script>
  window.REQUIRED_CODE_ERROR_MESSAGE = 'Please choose a country code';
  window.LOCALE = 'en';
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE = "The information provided is invalid. Please review the field format and try again.";
  window.REQUIRED_ERROR_MESSAGE = "This field cannot be left blank.";
  window.GENERIC_INVALID_MESSAGE = "The information provided is invalid. Please review the field format and try again.";
  window.translation = {
    common: {
      selectedList: '{quantity} list selected',
      selectedLists: '{quantity} lists selected',
      selectedOption: '{quantity} selected',
      selectedOptions: '{quantity} selected',
    }
  };
  var AUTOHIDE = Boolean(0);
</script>
<script defer src="https://sibforms.com/forms/end-form/build/main.js"></script>