---
const footerLinks = {
  Shop: [
    { label: 'Full Grain Leather',  href: '/shop/leather' },
    { label: 'Tools & Hardware',    href: '/shop/tools' },
    { label: 'Kits & Patterns',     href: '/shop/kits' },
    { label: 'Finishing Supplies',  href: '/shop/finishing' },
    { label: 'Books & Resources',   href: '/shop/books' },
  ],
  Company: [
    { label: 'Our Story',  href: '/about' },
    { label: 'Journal',    href: '/journal' },
    { label: 'Contact',    href: '/contact' },
    { label: 'FAQ',        href: '/faq' },
  ],
  Policies: [
    { label: 'Shipping & Returns', href: '/shipping' },
    { label: 'Privacy Policy',     href: '/privacy' },
    { label: 'Terms of Service',   href: '/terms' },
  ],
};
---

<footer class="bg-charcoal text-parchment/70">

  <!-- Top footer -->
  <div class="section-inner pt-16 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">

      <!-- Brand column -->
      <div class="lg:col-span-4">
        <!-- Logo -->
        <a href="/" class="inline-block mb-5 group">
          <span class="font-display font-semibold text-2xl text-parchment group-hover:text-gold transition-colors duration-200 block leading-none">
            Crown &amp; Covenant
          </span>
          <span class="label-caps text-[10px] text-gold/70 tracking-widest-2 mt-1 block">
            Leather Supply
          </span>
        </a>



        <!-- Decorative covenant seal quote -->
        <blockquote class="border-l-2 border-gold/30 pl-4 italic font-display text-base text-parchment/40">
          "Bound by craft. Marked by Legacy."
        </blockquote>
<p class="font-body text-base leading-relaxed text-parchment/60 max-w-xs mb-6">
&nbsp;
        </p>
        <p class="font-body text-base leading-relaxed text-parchment/60 max-w-xs mb-6">
        &nbsp;
                </p>
        <!-- Social links -->
        <div class="flex gap-4 mt-8">
          <a href="#" aria-label="Instagram" class="text-parchment/40 hover:text-gold transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" aria-label="Facebook" class="text-parchment/40 hover:text-gold transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="text-parchment/40 hover:text-gold transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      <div class="lg:col-span-5 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {Object.entries(footerLinks).map(([category, links]) => (
          <div>
            <h3 class="label-caps text-[10px] tracking-widest-2 text-gold/70 mb-4">{category}</h3>
            <ul class="space-y-2.5" role="list">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="font-body text-sm text-parchment/50 hover:text-parchment transition-colors duration-150"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Newsletter -->
      <div class="lg:col-span-3">
        <h3 class="label-caps text-[10px] tracking-widest-2 text-gold/70 mb-4">The Covenant Letter</h3>
        <p class="font-body text-sm text-parchment/50 mb-5 leading-relaxed">
          Craft tutorials, new stock arrivals, and dispatches from the bench. No noise — just signal.
        </p>
        <form class="flex flex-col gap-3" onsubmit="return false;">
          <label for="footer-email" class="sr-only">Email address</label>
          <input
            id="footer-email"
            type="email"
            placeholder="your@email.com"
            autocomplete="email"
            class="w-full bg-[#303c50] border border-parchment/10 text-parchment placeholder:text-parchment/25
                   font-body text-sm px-4 py-3
                   focus:outline-none focus:border-gold/50 transition-colors duration-200"
          />
          <button
            type="submit"
            class="w-full bg-oxblood text-parchment font-sans font-medium text-xs tracking-widest uppercase
                   py-3 border border-oxblood
                   hover:bg-oxblood-dark transition-colors duration-200"
          >
            Subscribe
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Decorative divider -->
  <div class="section-inner">
    <div class="h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
  </div>

  <!-- Bottom bar -->
  <div class="section-inner py-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="label-caps text-[9px] tracking-widest text-parchment/25">
        &copy; {new Date().getFullYear()} Crown &amp; Covenant Leather Supply, LLC &nbsp;·&nbsp; Meridian, Idaho
      </p>
      <p class="label-caps text-[9px] tracking-widest text-parchment/20">
        Est. MMXXVI &nbsp;·&nbsp; ccleathersupply.com
      </p>
    </div>
  </div>

</footer>
