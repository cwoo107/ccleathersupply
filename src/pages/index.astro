---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    label: 'Full Grain Leather',
    sub: 'Vegetable tanned, chrome tanned, and bridle hides',
    href: '/shop/leather',
    icon: '⬡',
  },
  {
    label: 'Tools & Hardware',
    sub: 'Pricking irons, awls, buckles, rivets, and more',
    href: '/shop/tools',
    icon: '⬡',
  },
  {
    label: 'Kits & Patterns',
    sub: 'Start your first project with everything included',
    href: '/shop/kits',
    icon: '⬡',
  },
  {
    label: 'Finishing Supplies',
    sub: 'Edge finishes, dyes, conditioners, and sealants',
    href: '/shop/finishing',
    icon: '⬡',
  },
];

const trustPoints = [
  { label: 'Premium Materials', body: 'We source only full-grain and top-grain hides from vetted tanneries.' },
  { label: 'Craftsman Curated', body: 'Every product is tested in our own shop before it reaches yours.' },
  { label: 'Fast Shipping',     body: 'Orders dispatched within one business day from Nampa, Idaho.' },
  { label: 'Real Support',      body: 'Call or email a human who actually leatherworks.' },
];
---

<BaseLayout title="Home" description="Crown & Covenant Leather Supply — premium leather hides, tools, hardware, and finishing supplies. Named after the Scottish Covenanters. Nampa, Idaho.">

  <Nav />

  <main>

    <!-- ═══════════════════════════════════════
         HERO
    ═══════════════════════════════════════ -->
    <section class="relative bg-tartan min-h-[90vh] flex flex-col items-center justify-center text-center px-6 overflow-hidden">

      <!-- Background gradient vignette -->
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal-dark/60 via-transparent to-charcoal-dark/80 pointer-events-none"></div>

      <!-- Decorative corner marks -->
      <div class="absolute top-8 left-8 w-12 h-12 border-t border-l border-gold/20 pointer-events-none"></div>
      <div class="absolute top-8 right-8 w-12 h-12 border-t border-r border-gold/20 pointer-events-none"></div>
      <div class="absolute bottom-8 left-8 w-12 h-12 border-b border-l border-gold/20 pointer-events-none"></div>
      <div class="absolute bottom-8 right-8 w-12 h-12 border-b border-r border-gold/20 pointer-events-none"></div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto">

        <!-- Overline label -->
        <p class="label-caps text-[11px] text-gold tracking-widest-3 mb-8 opacity-0 animate-[fadeUp_0.6s_0.1s_ease-out_forwards]">
          Est. MMXXVI &nbsp;·&nbsp; Meridian, Idaho &nbsp;
        </p>

        <!-- Main headline -->
        <h1 class="font-display font-semibold text-parchment leading-none mb-6
                    text-5xl sm:text-6xl lg:text-8xl
                    opacity-0 animate-[fadeUp_0.7s_0.25s_ease-out_forwards]">
          Bound by Craft.<br/>
          <em class="italic text-gold/90">Marked by Legacy.</em>
        </h1>

        <!-- Ornamental rule -->
        <div class="ornament-rule max-w-xs mx-auto my-8 opacity-0 animate-[fadeUp_0.6s_0.4s_ease-out_forwards]">
          <span class="text-gold/80 text-sm">✦</span>
          <span class="label-caps text-[9px] text-gold/80 tracking-widest-3 px-3">Crown &amp; Covenant</span>
          <span class="text-gold/80 text-sm">✦</span>
        </div>

        <!-- Subheadline -->
        <p class="font-body text-lg sm:text-xl text-parchment/65 max-w-xl mx-auto leading-relaxed mb-10
                   opacity-0 animate-[fadeUp_0.6s_0.5s_ease-out_forwards]">
          Premium handmade leather goods built for people who believe that honest work, lasting things, and a life faithfully lived all belong to the same kingdom.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-4
                     opacity-0 animate-[fadeUp_0.6s_0.65s_ease-out_forwards]">
          <a href="/shop" class="btn-primary">Shop the Supply</a>
          <a href="/about" class="btn-ghost">Our Story</a>
        </div>

      </div>

    </section>

    <!-- ═══════════════════════════════════════
         CATEGORY GRID
    ═══════════════════════════════════════ -->
    <section class="py-24 bg-parchment-50">
      <div class="section-inner">

        <div class="text-center mb-14">
          <p class="label-caps text-[11px] text-gold-dark tracking-widest-3 mb-4">What We Supply</p>
          <h2 class="heading-display text-4xl sm:text-5xl text-charcoal">The Full Range</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-charcoal/8">
          {categories.map((cat) => (
            <a
              href={cat.href}
              class="group bg-parchment-50 p-8 lg:p-10 flex flex-col gap-4
                     hover:bg-parchment-200 transition-colors duration-300 relative overflow-hidden"
            >
              <!-- Corner accent -->
              <div class="absolute top-0 right-0 w-0 h-0 border-t-[40px] border-r-[40px] border-t-transparent border-r-charcoal/5 group-hover:border-r-oxblood/10 transition-colors duration-300"></div>

              <!-- Icon placeholder — swap for real icons -->
              <div class="w-10 h-10 border border-gold/40 flex items-center justify-center text-gold/50 group-hover:border-gold group-hover:text-gold transition-all duration-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                  <line x1="7" y1="7" x2="7.01" y2="7"/>
                </svg>
              </div>

              <div>
                <h3 class="font-display font-semibold text-xl text-charcoal group-hover:text-oxblood transition-colors duration-200 mb-1.5">
                  {cat.label}
                </h3>
                <p class="font-body text-sm text-charcoal/55 leading-relaxed">{cat.sub}</p>
              </div>

              <span class="mt-auto label-caps text-[10px] text-oxblood/60 group-hover:text-oxblood tracking-widest flex items-center gap-1.5 transition-colors duration-200">
                Browse
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
             HERITAGE / STORY SECTION
        ═══════════════════════════════════════ -->
        <section class="py-24 bg-tartan-light relative overflow-hidden">

          <!-- Faint crown watermark -->
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-96 h-96 opacity-[0.025] pointer-events-none select-none"
               aria-hidden="true">
            <svg viewBox="0 0 200 160" fill="currentColor" class="text-oxblood w-full h-full">
              <path d="M10 140 L10 100 L50 120 L100 40 L150 120 L190 100 L190 140 Z"/>
              <rect x="5" y="140" width="190" height="18" rx="2"/>
              <circle cx="100" cy="45" r="9"/>
              <circle cx="22" cy="107" r="7"/>
              <circle cx="178" cy="107" r="7"/>
            </svg>
          </div>

          <div class="section-inner">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

              <!-- Text side -->
              <div>
                <h2 class="heading-display text-4xl sm:text-5xl text-charcoal mb-6 leading-tight">
                  Every Area of Life<br/>
                  <em class="italic text-oxblood">Under One Crown</em>
                </h2>

                <div class="space-y-4 font-body text-base text-charcoal/70 leading-relaxed">
                  <p>
                    We believe Christ reigns as king, not merely over the church, but over every sphere. Every throne, trade, table, and every hour of the working day. The crown in our name is His. The covenant is the one He keeps.
                  </p>
                  <p>
                    A wallet or a belt is a small thing, but it belongs to a life. A life that is lived entirely under Christ's kingship. We think the goods that accompany that life ought to be made with skill and care that honor He who is Lord over it.
                  </p>
                  <p>
                    Honest materials. Honest work. Built to last.
                  </p>
                </div>

                <div class="mt-8 pt-8 border-t border-charcoal/10 flex items-start gap-6">
                  <div>
                    <p class="font-display text-3xl font-semibold text-charcoal">100<span class="text-gold text-xl">%</span></p>
                    <p class="label-caps text-[10px] text-charcoal/50 tracking-widest mt-1">Full-Grain Only</p>
                  </div>
                  <div class="w-px h-12 bg-charcoal/10 self-center"></div>
                  <div>
                    <p class="font-display text-3xl font-semibold text-charcoal">By Hand</p>
                    <p class="label-caps text-[10px] text-charcoal/50 tracking-widest mt-1">Cut &amp; Stitched</p>
                  </div>
                  <div class="w-px h-12 bg-charcoal/10 self-center"></div>
                  <div>
                    <p class="font-display text-3xl font-semibold text-charcoal">Idaho</p>
                    <p class="label-caps text-[10px] text-charcoal/50 tracking-widest mt-1">Made &amp; Shipped</p>
                  </div>
                </div>

                <div class="mt-10">
                  <a href="/about" class="btn-outline">Read Our Full Story</a>
                </div>
              </div>

              <!-- Visual side — decorative covenant document motif -->
              <div class="relative flex items-center justify-center">
                <div class="relative w-full max-w-sm mx-auto">
                  <!-- Outer frame -->
                  <div class="border-2 border-charcoal/15 p-8 bg-parchment-50 shadow-xl shadow-charcoal/10">
                    <!-- Inner double border -->
                    <div class="border border-gold/25 p-8 flex flex-col items-center gap-6 text-center">

                      <!-- Crown icon SVG -->
                      <svg viewBox="0 0 120 90" class="w-28 text-charcoal/20 fill-current" aria-hidden="true">
                        <path d="M5 80 L5 55 L30 68 L60 20 L90 68 L115 55 L115 80 Z"/>
                        <rect x="2" y="80" width="116" height="10" rx="1"/>
                        <circle cx="60" cy="22" r="6"/>
                        <circle cx="12" cy="60" r="5"/>
                        <circle cx="108" cy="60" r="5"/>
                      </svg>

                      <div>
                        <p class="font-display italic text-2xl text-charcoal/50 leading-snug mb-2">
                          "There is not a square inch in the whole domain of our human existence over which Christ, who is Sovereign over all, does not cry: 'Mine!'"
                        </p>
                        <p class="label-caps text-[9px] text-charcoal/30 tracking-widest">
                          Abraham Kuyper
                        </p>
                      </div>

                      <!-- Seal line -->
                      <div class="w-full flex items-center gap-3">
                        <div class="flex-1 h-px bg-charcoal/10"></div>
                        <div class="w-8 h-8 rounded-full border-2 border-oxblood/30 flex items-center justify-center">
                          <div class="w-3 h-3 rounded-full bg-oxblood/20"></div>
                        </div>
                        <div class="flex-1 h-px bg-charcoal/10"></div>
                      </div>

                      <p class="label-caps text-[9px] text-charcoal/30 tracking-widest">
                        Crown &amp; Covenant Leather Supply <br/> Est. MMXXVI
                      </p>
                    </div>
                  </div>

                  <!-- Corner ornaments on outer frame -->
                  {[
                    'top-[-6px] left-[-6px]',
                    'top-[-6px] right-[-6px]',
                    'bottom-[-6px] left-[-6px]',
                    'bottom-[-6px] right-[-6px]',
                  ].map((pos) => (
                    <div class={`absolute ${pos} w-3 h-3 bg-gold/60 rotate-45`}></div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </section>

    <!-- ═══════════════════════════════════════
             TRUST / FEATURES BAR
        ═══════════════════════════════════════ -->
        <section class="py-16 bg-charcoal">
          <div class="section-inner">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
              {trustPoints.map((pt) => (
                <div class="flex gap-4 items-start">
                  <div class="shrink-0 mt-1 w-6 h-6 border border-gold/40 flex items-center justify-center">
                    <svg class="w-3 h-3 text-gold/70" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-sans font-medium text-sm text-parchment tracking-wide mb-1">{pt.label}</h3>
                    <p class="font-body text-sm text-parchment/45 leading-relaxed">{pt.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

    <!-- ═══════════════════════════════════════
         NEWSLETTER CTA
    ═══════════════════════════════════════ -->
    <section class="py-24 bg-parchment-50">
      <div class="section-inner">
        <div class="max-w-2xl mx-auto text-center">

          <p class="label-caps text-[11px] text-gold-dark tracking-widest-3 mb-4">The Covenant Letter</p>
          <h2 class="heading-display text-4xl sm:text-5xl text-charcoal mb-5">
            Dispatches from the Bench
          </h2>
          <p class="font-body text-lg text-charcoal/60 mb-10 leading-relaxed">
            New arrivals, craft tutorials, and the occasional history lesson on Scottish Presbyterians who also happened to be stubborn. No spam — we value your inbox like we value good leather.
          </p>

          <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="return false;">
            <label for="hero-email" class="sr-only">Email address</label>
            <input
              id="hero-email"
              type="email"
              placeholder="your@email.com"
              autocomplete="email"
              class="flex-1 bg-white border border-charcoal/20 text-charcoal placeholder:text-charcoal/30
                     font-body text-base px-5 py-3.5
                     focus:outline-none focus:border-oxblood transition-colors duration-200"
            />
            <button
              type="submit"
              class="btn-primary whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>

          <p class="mt-4 font-body text-xs text-charcoal/35">
            Unsubscribe at any time. We'll never share your address.
          </p>

        </div>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style is:global>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
