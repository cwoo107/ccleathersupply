---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const categories = [
{
    slug: 'wallets',
    label: 'Wallets',
    description: 'Handcrafted wallets.',
    count: 0,   // replace with real product count
  },
  {
      slug: 'not',
      label: 'A5 Notebook Cover',
      description: 'Sized to fit your favorite A5 notebook, sketchbook, or journal.',
      count: 0,   // replace with real product count
    },
  {
    slug: 'leather',
    label: 'Full Grain Leather',
    description: 'Vegetable tanned, chrome tanned, and bridle hides sourced from premium tanneries.',
    count: 0,   // replace with real product count
  },
  {
    slug: 'tools',
    label: 'Tools & Hardware',
    description: 'Pricking irons, stitching chisels, edge bevelers, rivets, buckles, and more.',
    count: 0,
  },
  {
    slug: 'kits',
    label: 'Kits & Patterns',
    description: 'Complete starter kits and printable patterns for wallets, belts, and bags.',
    count: 0,
  },
  {
    slug: 'finishing',
    label: 'Finishing Supplies',
    description: 'Edge finishes, neatsfoot oil, leather dyes, conditioners, and top coats.',
    count: 0,
  },
  {
    slug: 'books',
    label: 'Books & Resources',
    description: 'Leatherworking guides, pattern books, and references for all skill levels.',
    count: 0,
  },
];
---

<BaseLayout title="Shop" description="Browse Crown & Covenant's full range of leather hides, tools, hardware, kits, and finishing supplies.">

  <Nav />

  <main>

    <!-- Page header -->
    <div class="bg-charcoal py-16 text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-tartan opacity-60 pointer-events-none"></div>
      <div class="relative z-10 section-inner">
        <!-- Breadcrumb -->
        <nav class="mb-6" aria-label="Breadcrumb">
          <ol class="flex items-center justify-center gap-2 label-caps text-[10px] text-parchment/30 tracking-widest">
            <li><a href="/" class="hover:text-parchment/60 transition-colors">Home</a></li>
            <li aria-hidden="true" class="text-parchment/20">/</li>
            <li class="text-gold/60" aria-current="page">Shop</li>
          </ol>
        </nav>
        <h1 class="heading-display text-4xl sm:text-5xl text-parchment mb-3">The Supply</h1>
        <p class="font-body text-lg text-parchment/50 max-w-md mx-auto">
          Everything a leatherworker needs, curated by craftspeople.
        </p>
      </div>
    </div>

    <!-- Category grid -->
    <section class="py-20 bg-parchment-50">
      <div class="section-inner">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {categories.map((cat) => (
            <a
              href={`/shop/${cat.slug}`}
              class="group relative bg-white border border-charcoal/8 p-8
                     hover:border-oxblood/30 hover:shadow-lg hover:shadow-charcoal/8
                     transition-all duration-300 overflow-hidden"
            >
              <!-- Hover fill from bottom -->
              <div class="absolute inset-0 bg-gradient-to-t from-oxblood/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

              <div class="relative z-10">
                <!-- Placeholder image area — swap for real product image -->
                <div class="w-full h-40 bg-parchment-200 mb-6 flex items-center justify-center bg-tartan-light">
                  <svg class="w-10 h-10 text-charcoal/10" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21,15 16,10 5,21"/>
                  </svg>
                </div>

                <h2 class="font-display font-semibold text-2xl text-charcoal group-hover:text-oxblood transition-colors duration-200 mb-2">
                  {cat.label}
                </h2>
                <p class="font-body text-sm text-charcoal/55 leading-relaxed mb-5">{cat.description}</p>

                <div class="flex items-center justify-between">
                  <span class="label-caps text-[10px] text-charcoal/30 tracking-widest">
                    {cat.count > 0 ? `${cat.count} products` : 'Coming soon'}
                  </span>
                  <span class="label-caps text-[10px] text-oxblood/60 group-hover:text-oxblood tracking-widest flex items-center gap-1.5 transition-colors duration-200">
                    Browse
                    <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Empty state notice — remove once products are added -->
        <div class="mt-16 text-center py-12 border border-dashed border-charcoal/15">
          <p class="label-caps text-[10px] text-charcoal/30 tracking-widest-2 mb-3">Coming Soon</p>
          <p class="font-body text-base text-charcoal/50 max-w-sm mx-auto">
            Products are being added. Subscribe to The Covenant Letter to be notified when we launch.
          </p>
          <div class="mt-6">
            <a href="/#newsletter" class="btn-outline">Get Notified</a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>
