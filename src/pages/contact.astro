---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact" description="Get in touch with Crown & Covenant Leather Supply.">
  <Nav />
  <main>
    <div class="bg-charcoal py-16 text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-tartan opacity-60 pointer-events-none"></div>
      <div class="relative z-10 section-inner">
        <h1 class="heading-display text-4xl sm:text-5xl text-parchment mb-3">Contact</h1>
        <p class="font-body text-lg text-parchment/50">We'd love to hear from you.</p>
      </div>
    </div>

    <section class="py-24 bg-parchment-50">
      <div class="section-inner max-w-2xl mx-auto">
        <p class="label-caps text-[10px] text-charcoal/30 tracking-widest-2 text-center mb-12">
          Page coming soon — fill in your contact form or details here.
        </p>

        <!-- Contact form skeleton -->
        <form class="space-y-6" onsubmit="return false;">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="label-caps text-[10px] text-charcoal/50 tracking-widest block mb-2" for="name">Name</label>
              <input id="name" type="text" autocomplete="name" placeholder="Your Name"
                class="w-full border border-charcoal/15 bg-white text-charcoal font-body text-base
                       px-4 py-3 focus:outline-none focus:border-oxblood transition-colors duration-200" />
            </div>
            <div>
              <label class="label-caps text-[10px] text-charcoal/50 tracking-widest block mb-2" for="email">Email</label>
              <input id="email" type="email" autocomplete="email" placeholder="your@email.com"
                class="w-full border border-charcoal/15 bg-white text-charcoal font-body text-base
                       px-4 py-3 focus:outline-none focus:border-oxblood transition-colors duration-200" />
            </div>
          </div>
          <div>
            <label class="label-caps text-[10px] text-charcoal/50 tracking-widest block mb-2" for="subject">Subject</label>
            <input id="subject" type="text" placeholder="Order inquiry, product question, etc."
              class="w-full border border-charcoal/15 bg-white text-charcoal font-body text-base
                     px-4 py-3 focus:outline-none focus:border-oxblood transition-colors duration-200" />
          </div>
          <div>
            <label class="label-caps text-[10px] text-charcoal/50 tracking-widest block mb-2" for="message">Message</label>
            <textarea id="message" rows="6" placeholder="Tell us how we can help."
              class="w-full border border-charcoal/15 bg-white text-charcoal font-body text-base
                     px-4 py-3 focus:outline-none focus:border-oxblood transition-colors duration-200 resize-y"></textarea>
          </div>
          <div class="text-right">
            <button type="submit" class="btn-primary">Send Message</button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
